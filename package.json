{
  "name": "typst-download",
  "version": "1.0.0",
  "description": "Download Typst templates from GitHub into a local templates folder.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "typst-download": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typst",
    "github",
    "cli",
    "templates"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "isomorphic-git": "^1.37.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
